# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"

# ==========================================
# DATABASE CONFIGURATION (PRISMA / POSTGRESQL)
# ==========================================
# Format: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE_NAME]?schema=public
DATABASE_URL="postgresql://postgres:password123@localhost:5432/fhc_health_db?schema=public"

# ==========================================
# AUTHENTICATION & SECURITY (JWT)
# ==========================================
# Gunakan string acak minimal 32 karakter (256-bit) untuk produksi
JWT_SECRET="fhc-super-secret-jwt-key-dev-2026-replace-in-prod"
JWT_EXPIRES_IN="7d"

# ==========================================
# MAIL SERVICE (VERIFICATION & RESET PASSWORD)
# ==========================================
# Contoh menggunakan layanan SMTP (seperti Resend, SendGrid, atau Mailtrap untuk dev)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="your_mailtrap_user"
SMTP_PASS="your_mailtrap_password"
MAIL_FROM_ADDRESS="no-reply@fhc-platform.com"
MAIL_FROM_NAME="FHC Health Platform"